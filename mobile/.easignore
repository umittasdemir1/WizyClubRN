# Exclude backup zips explicitly (even if deleted, good habit)
*.zip
*.tar.gz

# Exclude native builds 
android/
ios/

# Exclude node_modules
node_modules/

# Exclude backend and parent environment from EAS build
../backend/
../backups/
../maintenance_scripts/
../r2-mcp/
../.git/

# Exclude local logs and temporary files
doctor_output*.txt
doctor_full*.txt
doctor_utf8*.txt
doctor_final*.txt
doctor_full.txt
doctor_output.txt
*.log
npm-debug.*
yarn-error.*

# Exclude native and generated folders (EAS will regenerate if needed)
android/
ios/
.expo/
dist/
web-build/
node_modules/
backend/
backups/
maintenance_scripts/
r2-mcp/
