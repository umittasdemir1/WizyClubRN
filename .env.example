# Central environment file (single source of truth)
# Use: cp .env.example .env
# Then run: bash scripts/sync-env.sh all

# ---------------------------
# Shared (Backend + Mobile)
# ---------------------------
PORT=3000
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=your_supabase_anon_key
# Optional but recommended for backend write operations:
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ---------------------------
# Cloudflare R2 (Backend)
# ---------------------------
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_URL=https://your-r2-public-url.example.com

# ---------------------------
# Mobile Public Config
# ---------------------------
# Home LAN example: http://192.168.x.x:3000
# Ngrok example: https://xxxx.ngrok-free.app
EXPO_PUBLIC_API_URL=http://192.168.0.138:3000

# Optional overrides (if omitted, SUPABASE_URL/SUPABASE_KEY are reused for mobile)
# EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional RevenueCat public keys
# EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_xxx
# EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_xxx

# ---------------------------
# Optional STT (Backend)
# ---------------------------
# GOOGLE_APPLICATION_CREDENTIALS=./backend/google-credentials.json
# GOOGLE_CLOUD_PROJECT_ID=your_google_cloud_project_id

# ---------------------------
# Optional Codex MCP Tokens
# ---------------------------
# Required only if you want the repo-managed Supabase MCP entry:
# SUPABASE_MCP_ACCESS_TOKEN=your_supabase_personal_access_token
