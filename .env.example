# WizyClub root environment
# Single source of truth for backend/, mobile/, and r2-mcp/.
# Copy to .env, fill real values, then run: bash scripts/sync-env.sh all

# ---------------------------
# Core App
# ---------------------------
PORT=3000
EXPO_PUBLIC_API_URL=http://192.168.0.138:3000

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=your_supabase_anon_key
# Optional but recommended for backend write operations:
SUPABASE_SERVICE_ROLE_KEY=

# Optional mobile overrides. Leave blank to reuse SUPABASE_URL and SUPABASE_KEY.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Optional mobile extras.
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=

# ---------------------------
# Storage (Cloudflare R2)
# ---------------------------
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_URL=https://your-r2-public-url.example.com

# ---------------------------
# Google / Maps
# ---------------------------
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=./backend/google-credentials.json
GOOGLE_PLACES_API_KEY=
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_ANDROID_API_KEY=
GOOGLE_MAPS_IOS_API_KEY=

# ---------------------------
# Codex MCP (Optional)
# ---------------------------
GITHUB_PERSONAL_ACCESS_TOKEN=
SUPABASE_MCP_ACCESS_TOKEN=
# Leave blank unless you explicitly want direct Postgres MCP:
POSTGRES_MCP_URL=
# Set to 1 only if you explicitly want Netlify MCP:
NETLIFY_MCP_ENABLED=

# ---------------------------
# Codex Telegram Reporter (Optional)
# ---------------------------
# Set to 1 to enable Telegram progress notifications for Codex sessions.
CODEX_TELEGRAM_ENABLED=0
CODEX_TELEGRAM_BOT_TOKEN=
CODEX_TELEGRAM_CHAT_ID=
CODEX_TELEGRAM_PROJECT_NAME=WizyClubRN
# Optional tuning:
CODEX_TELEGRAM_MAX_FILES=6
CODEX_TELEGRAM_POLL_SECONDS=180
